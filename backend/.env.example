# ── DriveIndia Backend — .env ──────────────────────────────
# Copy this file: cp .env.example .env  then fill in values

# MongoDB URI (Atlas ya local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/driveindia?retryWrites=true&w=majority

# Local MongoDB use karna ho to:
# MONGO_URI=mongodb://localhost:27017/driveindia

# JWT Secret (koi bhi long random string)
JWT_SECRET=driveindia_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000

# Frontend URL (CORS ke liye)
CLIENT_URL=http://localhost:5173

# Razorpay (Indian Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Twilio WhatsApp OTP (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE=+1415xxxxxxx
